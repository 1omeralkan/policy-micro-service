<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.6.xsd">

    <changeSet id="003-1" author="omeralkan">
        <createTable tableName="error_messages">
            <column name="error_code" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="language" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="message" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey tableName="error_messages" columnNames="error_code, language" constraintName="pk_error_messages"/>
    </changeSet>

    <changeSet id="003-2" author="omeralkan">
        <insert tableName="error_messages">
            <column name="error_code" value="POL-404"/>
            <column name="language" value="tr"/>
            <column name="message" value="Aradığınız poliçe sistemde bulunamadı."/>
        </insert>
        <insert tableName="error_messages">
            <column name="error_code" value="POL-404"/>
            <column name="language" value="en"/>
            <column name="message" value="The requested policy could not be found."/>
        </insert>
    </changeSet>

</databaseChangeLog>